OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemma-4-26b-a4b-it:free

EMBEDDING_API_KEY=your-openrouter-api-key
EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
EMBEDDING_PROVIDER=openrouter
EMBEDDING_MODEL=openai/text-embedding-3-small

LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=shl-conversational-recommender

SHL_CATALOG_PATH=app/catalog/normalized_catalog.json
USE_LLM_EXTRACTION=true
USE_LLM_GENERATION=true
RERANKER_MODEL=BAAI/bge-reranker-base
DISABLE_BGE_RERANKER=true
OPENROUTER_SITE_URL=http://localhost:8000
OPENROUTER_APP_NAME=SHL Conversational Assessment Recommender
LOG_LEVEL=INFO
